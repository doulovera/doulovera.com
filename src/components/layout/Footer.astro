---
import type { FooterData } from "../../data/portfolio";
import ButtonLink from "../ui/ButtonLink.astro";
import SurfaceCard from "../ui/SurfaceCard.astro";

const { heading, note, actions } = Astro.props as FooterData;
---

<footer id="contact" class="mx-auto mb-4 w-full max-w-290 px-4">
  <SurfaceCard className="flex flex-col items-start justify-between gap-6 rounded-3xl p-6 md:flex-row md:items-center">
    <div class="relative z-10 grid gap-1">
      <p class="font-(--display-font) text-2xl uppercase tracking-[0.02em] text-(--chrome)">
        {heading}
      </p>
      <p class="text-(--muted)">{note}</p>
    </div>
    <div class="relative z-10 flex flex-wrap gap-4">
      {actions.map((action) => (
        <ButtonLink href={action.href} label={action.label} variant="inline" />
      ))}
    </div>
  </SurfaceCard>
</footer>
