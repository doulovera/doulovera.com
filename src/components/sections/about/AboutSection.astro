---
import type { AboutSectionData } from "../../../data/portfolio";
import MediaCard from "../../ui/MediaCard.astro";
import SectionHeading from "../../ui/SectionHeading.astro";
import SurfaceCard from "../../ui/SurfaceCard.astro";

const { title, description, portrait } = Astro.props as AboutSectionData;
const paragraphs = description
  .split(/\n{2,}/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
---

<section id="about" class="grid gap-8">
  <SectionHeading title={title} />
  <SurfaceCard strong={true} className="p-0">
    <div class="relative z-10 grid items-stretch lg:grid-cols-[minmax(0,1.05fr)_minmax(300px,0.85fr)]">
      <div class="flex flex-col gap-8 p-6 md:p-12">
        {paragraphs.map((paragraph) => (
          <p class="whitespace-pre-line text-(--muted)">{paragraph}</p>
        ))}
      </div>
      <div class="border-t border-white/10 lg:border-t-0 lg:border-l">
        <MediaCard
          src={portrait}
          alt="doulovera"
          label="doulovera"
          ratio="portrait"
          className="h-full rounded-none border-0 shadow-none"
          imageClassName="grayscale brightness-90 hover:grayscale-0 transition duration-300"
        />
      </div>
    </div>
  </SurfaceCard>
</section>
