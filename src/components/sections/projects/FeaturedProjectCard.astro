---
import type { ProjectEntry } from "../../../data/portfolio";
import ButtonLink from "../../ui/ButtonLink.astro";
import MediaCard from "../../ui/MediaCard.astro";
import TechTag from "../../ui/TechTag.astro";

interface Props {
  project: ProjectEntry;
  reverse?: boolean;
}

const { project, reverse = false } = Astro.props;
---

<article class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(280px,0.85fr)]">
  <div class={reverse ? "lg:order-2" : ""}>
    <MediaCard
      src={project.image}
      alt={`${project.title} preview`}
      ratio="landscape"
      className="rounded-[2rem]"
    />
  </div>

  <div class={`grid gap-5 ${reverse ? "lg:order-1" : ""}`}>
    <div class="flex flex-wrap gap-2">
      {project.technologies.map((technology) => (
        <TechTag label={technology} />
      ))}
    </div>

    <div class="grid gap-3">
      <h3 class="font-[var(--display-font)] text-[clamp(2rem,4vw,3.3rem)] leading-[0.9] font-bold uppercase tracking-[0.02em] text-[var(--chrome)]">
        {project.title}
      </h3>
      <p class="text-[1.05rem] text-[var(--muted)]">{project.description}</p>
    </div>

    {(project.githubUrl || project.previewUrl) && (
      <div class="flex flex-wrap gap-3">
        {project.githubUrl && <ButtonLink href={project.githubUrl} label="GitHub" variant="ghost" />}
        {project.previewUrl && <ButtonLink href={project.previewUrl} label="Preview" variant="primary" />}
      </div>
    )}
  </div>
</article>
