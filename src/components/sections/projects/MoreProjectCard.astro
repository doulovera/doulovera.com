---
import type { CompactProjectEntry } from "../../../data/portfolio";
import ButtonLink from "../../ui/ButtonLink.astro";
import SurfaceCard from "../../ui/SurfaceCard.astro";
import TechTag from "../../ui/TechTag.astro";

interface Props {
  project: CompactProjectEntry;
}

const { project } = Astro.props;
const cardHref = project.previewUrl ?? project.githubUrl;
const isExternalCardLink = cardHref?.startsWith("http") ?? false;
---

<SurfaceCard
  as="article"
  className="grid min-h-[17rem] content-between gap-6 p-5 transition duration-200 hover:-translate-y-0.5 hover:border-[color:rgba(152,255,218,0.22)] hover:bg-[linear-gradient(180deg,rgba(152,255,218,0.06),transparent_32%),var(--panel)] focus-within:-translate-y-0.5 focus-within:border-[color:rgba(152,255,218,0.22)] focus-within:bg-[linear-gradient(180deg,rgba(152,255,218,0.06),transparent_32%),var(--panel)]"
>
  {cardHref && (
    <a
      aria-label={`Open ${project.title}`}
      class="absolute inset-0 z-10 rounded-[2rem] focus:outline-none"
      href={cardHref}
      target={isExternalCardLink ? "_blank" : undefined}
      rel={isExternalCardLink ? "noreferrer" : undefined}
    ></a>
  )}

  <div class="relative flex items-start justify-between gap-4">
    <span
      aria-hidden="true"
      class="flex h-12 w-12 items-center justify-center rounded-2xl border border-[color:rgba(152,255,218,0.14)] bg-[radial-gradient(circle_at_50%_50%,rgba(152,255,218,0.12),transparent_60%),rgba(152,255,218,0.05)] font-[var(--display-font)] text-xl leading-none text-[var(--muted)]"
    >
      ↗️
    </span>
    {(project.githubUrl || project.previewUrl) && (
      <div class="relative z-20 flex flex-wrap justify-end gap-4">
        {project.githubUrl && <ButtonLink href={project.githubUrl} label="GitHub" variant="inline" />}
        {project.previewUrl && <ButtonLink href={project.previewUrl} label="Preview" variant="inline" />}
      </div>
    )}
  </div>

  <div class="grid gap-3">
    <h3 class="font-[var(--display-font)] text-[1.15rem] leading-none font-bold uppercase tracking-[0.02em] text-[var(--chrome)]">
      {project.title}
    </h3>
    <div class="flex flex-wrap gap-2">
      {project.technologies.map((technology) => (
        <TechTag label={technology} />
      ))}
    </div>
  </div>
</SurfaceCard>
