---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary" | "ghost" | "inline";
  className?: string;
}

const { href, label, variant = "ghost", className = "" } = Astro.props;
const isExternal = href.startsWith("http");

const baseClass =
  "inline-flex items-center justify-center rounded-full border font-[var(--accent-font)] text-[0.74rem] uppercase tracking-[0.06em] transition duration-200";

const variantClass = {
  primary:
    "min-h-12 border-[color:rgba(152,255,218,0.28)] bg-linear-to-br from-[var(--mint)] to-[#d7fff0] px-4 py-3 text-[#081211] shadow-[0_12px_24px_rgba(152,255,218,0.16)] hover:-translate-y-px",
  secondary:
    "min-h-12 border-[color:rgba(255,141,107,0.28)] bg-linear-to-br from-[var(--ember)] to-[#ffc1ae] px-4 py-3 text-[#081211] shadow-[0_12px_24px_rgba(255,141,107,0.16)] hover:-translate-y-px",
  ghost:
    "min-h-12 border-white/10 bg-white/[0.025] px-4 py-3 text-[var(--text)] hover:-translate-y-px hover:border-[color:rgba(152,255,218,0.22)] hover:bg-[rgba(152,255,218,0.05)]",
  inline:
    "min-h-0 border-transparent bg-transparent px-0 py-0 text-[var(--muted)] hover:text-[var(--text)]"
}[variant];
---

<a
  class={`${baseClass} ${variantClass} ${className}`.trim()}
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noreferrer" : undefined}
>
  <span>{label}</span>
</a>
