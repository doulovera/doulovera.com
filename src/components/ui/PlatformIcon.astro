---
interface Props {
  icon: "github" | "instagram" | "linkedin" | "notion";
  className?: string;
}

const { icon, className = "" } = Astro.props;

const svgClass = className || "h-8 w-8";
---

{
  icon === "github" && (
    <svg
      aria-hidden="true"
      class={svgClass}
      fill="currentColor"
      focusable="false"
      viewBox="0 0 24 24"
    >
      <path d="M12 .5C5.65.5.5 5.65.5 12.16c0 5.21 3.35 9.63 7.99 11.18.58.1.79-.26.79-.57 0-.28-.01-1.2-.01-2.18-3.25.72-3.93-1.41-3.93-1.41-.53-1.39-1.3-1.76-1.3-1.76-1.07-.75.08-.74.08-.74 1.18.09 1.8 1.24 1.8 1.24 1.06 1.84 2.77 1.31 3.45 1 .11-.78.41-1.31.74-1.61-2.59-.3-5.31-1.31-5.31-5.87 0-1.3.46-2.36 1.22-3.2-.12-.31-.53-1.55.12-3.23 0 0 .99-.33 3.25 1.22A11.17 11.17 0 0 1 12 6.12c.99 0 1.99.14 2.92.42 2.26-1.55 3.24-1.22 3.24-1.22.65 1.68.24 2.92.12 3.23.76.84 1.22 1.9 1.22 3.2 0 4.57-2.73 5.56-5.33 5.85.42.37.8 1.11.8 2.24 0 1.62-.01 2.92-.01 3.32 0 .31.21.67.8.56 4.63-1.56 7.97-5.97 7.97-11.18C23.5 5.65 18.35.5 12 .5Z"></path>
    </svg>
  )
}

{
  icon === "instagram" && (
    <svg
      aria-hidden="true"
      class={svgClass}
      fill="none"
      focusable="false"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
      viewBox="0 0 24 24"
    >
      <rect x="3.5" y="3.5" width="17" height="17" rx="5.5"></rect>
      <circle cx="12" cy="12" r="4.2"></circle>
      <circle cx="17.5" cy="6.8" r="0.9" fill="currentColor" stroke="none"></circle>
    </svg>
  )
}

{
  icon === "linkedin" && (
    <svg
      aria-hidden="true"
      class={svgClass}
      fill="currentColor"
      focusable="false"
      viewBox="0 0 24 24"
    >
      <path d="M4.98 3.5a2.24 2.24 0 1 0 0 4.48 2.24 2.24 0 0 0 0-4.48ZM3 8.92h3.96V21H3V8.92Zm6.2 0h3.8v1.65h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.73 4.78 6.28V21h-3.96v-5.46c0-1.3-.02-2.98-1.77-2.98-1.77 0-2.04 1.42-2.04 2.88V21H9.2V8.92Z"></path>
    </svg>
  )
}

{
  icon === "notion" && (
    <svg
      aria-hidden="true"
      class={svgClass}
      fill="none"
      focusable="false"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.55"
      viewBox="0 0 24 24"
    >
      <path d="M5.4 4.75 15.9 4l2.7 2.08v12.34l-10.58.83-2.62-2.02V4.75Z"></path>
      <path d="m5.58 4.83 2.65 2.05 10.37-.8"></path>
      <path d="M8.44 6.88v12.34"></path>
      <path d="m11 10.2 3.3 5.18V9.57"></path>
    </svg>
  )
}
