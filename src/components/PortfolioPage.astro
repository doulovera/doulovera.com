---
import Navbar from "./nav/Navbar.astro";
import MainSection from "./sections/MainSection.astro";
import ExperienceSection from "./sections/ExperienceSection.astro";
import ProjectsSection from "./sections/ProjectsSection.astro";
import MoreProjectsSection from "./sections/MoreProjectsSection.astro";
import AboutSection from "./sections/AboutSection.astro";
import FooterSection from "./sections/FooterSection.astro";
import type { Translations } from "../i18n/types";

type Props = {
  t: Translations;
};

const { t } = Astro.props;
---

<Navbar locale={t.locale} labels={t.nav} />

<main class="relative mx-auto w-full max-w-6xl px-4 pb-10 sm:px-6">
  <MainSection content={t.main} labels={t.cta} links={t.links} />
  <ExperienceSection title={t.sectionTitles.experience} items={t.experience} />
  <ProjectsSection title={t.sectionTitles.projects} projects={t.featuredProjects} labels={t.cta} />
  <MoreProjectsSection title={t.sectionTitles.moreProjects} projects={t.moreProjects} labels={t.cta} />
  <AboutSection content={t.about} />
</main>

<div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
  <FooterSection links={t.links} labels={t.cta} note={t.footerNote} />
</div>
